# ==============================================================================
# RAG Framework - Backend Environment Configuration
# ==============================================================================
# Copy this file to .env and update with your actual values
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
APP_NAME=RAG Framework
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_framework
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_framework
DB_USER=postgres
DB_PASSWORD=password
DB_ECHO=false  # Set to true to log all SQL queries

# ------------------------------------------------------------------------------
# Milvus Configuration (Vector Database)
# ------------------------------------------------------------------------------
# Milvus connection settings
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
MILVUS_DB_NAME=default

# Milvus advanced settings
MILVUS_CONNECTION_TIMEOUT=10  # seconds
MILVUS_KEEP_ALIVE_TIMEOUT=30  # seconds
MILVUS_SECURE=false  # Set to true for TLS/SSL

# ------------------------------------------------------------------------------
# FAISS Configuration (Fallback Vector Index)
# ------------------------------------------------------------------------------
FAISS_INDEX_DIR=./data/faiss_indexes
FAISS_AUTO_SAVE_INTERVAL=300  # Auto-save every 5 minutes
FAISS_USE_GPU=false  # Set to true if faiss-gpu is installed

# ------------------------------------------------------------------------------
# Vector Index Settings
# ------------------------------------------------------------------------------
VECTOR_INDEX_DEFAULT_PROVIDER=milvus  # or 'faiss'
VECTOR_INDEX_BATCH_SIZE=1000
VECTOR_INDEX_MAX_QUERY_TIMEOUT=10  # seconds
VECTOR_INDEX_AUTO_PERSIST_ENABLED=true
VECTOR_INDEX_PERSIST_INTERVAL=300  # seconds

# ------------------------------------------------------------------------------
# API Settings
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true  # Set to false in production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ------------------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------------------
UPLOAD_DIR=./uploads
RESULTS_DIR=./results
MAX_UPLOAD_SIZE_MB=100

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_DIR=./logs
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=30

# ------------------------------------------------------------------------------
# Redis (Optional - for caching)
# ------------------------------------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# External Services
# ------------------------------------------------------------------------------
# OpenAI API (for embeddings)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ------------------------------------------------------------------------------
# Performance Tuning
# ------------------------------------------------------------------------------
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------
ENABLE_QUERY_HISTORY=true
ENABLE_STATISTICS_TRACKING=true
ENABLE_AUTO_INDEXING=true
ENABLE_RESULT_PERSISTENCE=true

# ------------------------------------------------------------------------------
# Docling Serve Configuration (Document Parsing Service)
# ------------------------------------------------------------------------------
DOCLING_SERVE_URL=http://localhost:5001
DOCLING_SERVE_API_KEY=  # Optional, if authentication is enabled
DOCLING_SERVE_TIMEOUT=300  # Request timeout in seconds
DOCLING_SERVE_ENABLED=true  # Set to false to disable

# ==============================================================================
# End of Configuration
# ==============================================================================
