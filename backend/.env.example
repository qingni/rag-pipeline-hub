# ==============================================================================
# RAG Framework - Backend Environment Configuration
# ==============================================================================
# Copy this file to .env and update with your actual values
# ==============================================================================

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:password@localhost/dbname  # Production

# ------------------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------------------
UPLOAD_DIR=../uploads
RESULTS_DIR=./results

# ------------------------------------------------------------------------------
# File Upload Limits
# ------------------------------------------------------------------------------
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# ------------------------------------------------------------------------------
# Milvus Vector Store
# ------------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ------------------------------------------------------------------------------
# Vector Index Settings
# ------------------------------------------------------------------------------
VECTOR_INDEX_DEFAULT_PROVIDER=milvus  # or 'faiss'

# ------------------------------------------------------------------------------
# Embedding API Configuration (后端调用外部 API)
# ------------------------------------------------------------------------------
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE_URL=http://your-embedding-api-server/api/llmproxy
EMBEDDING_DEFAULT_MODEL=qwen3-embedding-8b

# ------------------------------------------------------------------------------
# Embedding Retry Configuration
# ------------------------------------------------------------------------------
EMBEDDING_MAX_RETRIES=3
EMBEDDING_TIMEOUT=60
EMBEDDING_INITIAL_DELAY=1
EMBEDDING_MAX_DELAY=32

# ------------------------------------------------------------------------------
# Embedding Storage Configuration
# ------------------------------------------------------------------------------
EMBEDDING_RESULTS_DIR=results/embedding

# ------------------------------------------------------------------------------
# Embedding Client Authentication (前端到后端的认证)
# ------------------------------------------------------------------------------
# EMBEDDING_CLIENT_API_KEY=change-me  # 取消注释以启用前端认证
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Reranker API Configuration (混合检索精排)
# ------------------------------------------------------------------------------
# 支持模型: qwen3-reranker-4b
RERANKER_MODEL=qwen3-reranker-4b
RERANKER_API_KEY=your_reranker_api_key_here
RERANKER_API_BASE_URL=http://your-reranker-api-server/api/llmproxy
RERANKER_TIMEOUT=30
RERANKER_TOP_N=20
# 多 Collection 合并后送入 Reranker 的候选上限（按 RRF_score 截断）
RERANKER_MULTI_COLLECTION_TOP_N=40
# 动态阈值上限（全局）
RERANKER_DYNAMIC_THRESHOLD_MAX=0.5
# 单主题查询动态阈值上限（更宽松，减少误杀）
RERANKER_DYNAMIC_THRESHOLD_MAX_SINGLE_TOPIC=0.45
# 阈值过滤保底召回数
RERANKER_MIN_RESULTS=5

# 文档来源多样性控制（第 3 层防御）
MAX_RESULTS_PER_DOC=2
# 单主题查询时放宽每文档上限；设为 0 表示单主题查询下关闭该限制
MAX_RESULTS_PER_DOC_SINGLE_TOPIC=3
# 单主题查询判定的最大长度（字符）
SINGLE_TOPIC_QUERY_MAX_LENGTH=40

# ------------------------------------------------------------------------------
# Contextual Retrieval Configuration (Anthropic-style chunk context enrichment)
# ------------------------------------------------------------------------------
# 在 embedding 阶段为每个 chunk 生成文档级上下文描述，提升检索精度
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_RETRIEVAL_MODEL=qwen3.5-35b-a3b
CONTEXTUAL_RETRIEVAL_TEMPERATURE=0.0
CONTEXTUAL_RETRIEVAL_MAX_TOKENS=128
CONTEXTUAL_RETRIEVAL_TIMEOUT=30
CONTEXTUAL_RETRIEVAL_MAX_WORKERS=5
CONTEXTUAL_RETRIEVAL_BATCH_SIZE=10

# ------------------------------------------------------------------------------
# Docling Serve Configuration (Document Parsing Service)
# ------------------------------------------------------------------------------
DOCLING_SERVE_URL=http://localhost:5001
DOCLING_SERVE_API_KEY=  # Optional, if authentication is enabled
DOCLING_SERVE_TIMEOUT=300  # Request timeout in seconds
DOCLING_SERVE_ENABLED=true  # Set to false to disable

# ==============================================================================
# End of Configuration
# ==============================================================================
